# eagendas cloud connection
# Region: US (United States, default), BR (Brazil), or HOMOLOG (staging)
EAGENDAS_REGION=US
# Optional: override the API URL (takes precedence over region)
# EAGENDAS_API_URL=https://eagendas.com/api/v3
EAGENDAS_API_TOKEN=your-eagendas-api-token

# Database
DB_USER=proxy
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
DB_NAME=eagendas_pii
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
DATABASE_URL_SYNC=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis
REDIS_URL=redis://redis:6379/0

# Admin panel
ADMIN_SECRET_KEY=change-me-to-a-random-string

# SMTP (email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=scheduling@example.com
SMTP_FROM_NAME=Scheduling System

# SMS notifications (optional)
# SMS_ENABLED=true
# SMS_PROVIDER=twilio
# SMS_API_KEY=your-account-sid
# SMS_API_SECRET=your-auth-token
# SMS_FROM_NUMBER=+1234567890

# WhatsApp notifications (optional)
# WHATSAPP_ENABLED=true
# WHATSAPP_PROVIDER=evolution
# WHATSAPP_API_URL=https://your-evolution-api.com
# WHATSAPP_API_KEY=your-api-key
# WHATSAPP_FROM_NUMBER=+5511999999999

# Webhook relay (forward enriched webhooks to client systems)
WEBHOOK_RELAY_TARGET=https://erp.client.local/api/webhooks
WEBHOOK_RELAY_AUTH=Bearer client-internal-token

# PII settings
PII_PSEUDONYM_PREFIX=Citizen
PII_ENCRYPTION_KEY=change-me-32-byte-key-here-12345
